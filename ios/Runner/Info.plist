<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Flutter engine settings -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ARR DMRV</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>in.arrplatform.mobile</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>ARR DMRV</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Minimum iOS version -->
	<key>MinimumOSVersion</key>
	<string>13.0</string>

	<!-- Flutter standard entries -->
	<key>NSPrincipalClass</key>
	<string>FlutterApplication</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- Embedded Flutter views (needed for flutter_map, camera preview) -->
	<key>io.flutter.embedded_views_preview</key>
	<true/>

	<!-- Background execution modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>   <!-- GPS tracking during offline sync -->
		<string>fetch</string>      <!-- Background data sync -->
	</array>

	<!-- Privacy usage descriptions — required for App Store review -->

	<!-- Camera — in-app tree monitoring photos with GPS EXIF -->
	<key>NSCameraUsageDescription</key>
	<string>ARR DMRV needs camera access to capture tree monitoring photos with GPS metadata for carbon project verification.</string>

	<!-- Location — while in use (foreground GPS for tree planting) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ARR DMRV needs GPS location to record precise tree coordinates for VM0047 carbon monitoring.</string>

	<!-- Location — always (background sync tracks movement in field) -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ARR DMRV uses GPS location to tag tree monitoring photos and sync field data when connectivity is restored.</string>

	<!-- Photo library — saving captured monitoring photos -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ARR DMRV needs photo library access to save tree monitoring photos for carbon project verification.</string>

	<!-- Photo library — adding new photos (image_picker write access) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>ARR DMRV saves captured field photos to your photo library.</string>

	<!-- Microphone — AVCaptureSession requires this even when audio unused -->
	<key>NSMicrophoneUsageDescription</key>
	<string>ARR DMRV camera requires microphone permission as part of iOS camera session initialisation.</string>

	<!-- UI orientation — support portrait + landscape for tablet field use -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- App Transport Security — allow local API during dev -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
